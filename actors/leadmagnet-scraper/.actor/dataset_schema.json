{
  "actorSpecification": 1,
  "fields": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Business Name",
        "type": "string",
        "nullable": true,
        "example": "ABC Digital Marketing Agency"
      },
      "category": {
        "title": "Category",
        "type": "string",
        "nullable": true,
        "example": "Marketing Agency"
      },
      "address": {
        "title": "Address",
        "type": "string",
        "nullable": true,
        "example": "123 Main Street, New York, NY 10001"
      },
      "phone": {
        "title": "Phone Number",
        "type": "string",
        "nullable": true,
        "example": "+1 234 567 890"
      },
      "website": {
        "title": "Website",
        "type": "string",
        "format": "uri",
        "nullable": true,
        "example": "https://abcdigital.com"
      },
      "email": {
        "title": "Email Address",
        "type": "string",
        "format": "email",
        "nullable": true,
        "example": "contact@abcdigital.com"
      },
      "rating": {
        "title": "Rating",
        "type": "number",
        "nullable": true,
        "example": 4.7
      },
      "reviewsCount": {
        "title": "Review Count",
        "type": "integer",
        "nullable": true,
        "example": 128
      },
      "priceRange": {
        "title": "Price Range",
        "type": "string",
        "nullable": true,
        "example": "$$"
      },
      "openingHours": {
        "title": "Opening Hours",
        "type": "array",
        "nullable": true,
        "items": { "type": "string" }
      },
      "amenities": {
        "title": "Amenities",
        "type": "array",
        "nullable": true,
        "items": { "type": "string" }
      },
      "imageUrl": {
        "title": "Image URL",
        "type": "string",
        "format": "uri",
        "nullable": true
      },
      "placeId": {
        "title": "Place ID",
        "type": "string",
        "nullable": true,
        "example": "ChIJN1t_tDeuEmsRUsoyG83frY4"
      },
      "latitude": {
        "title": "Latitude",
        "type": "number",
        "nullable": true,
        "example": 40.7128
      },
      "longitude": {
        "title": "Longitude",
        "type": "number",
        "nullable": true,
        "example": -74.006
      },
      "searchQuery": {
        "title": "Search Query",
        "type": "string",
        "nullable": true,
        "example": "dentist Austin TX"
      },
      "scrapedAt": {
        "title": "Scraped At",
        "type": "string",
        "format": "date-time",
        "nullable": true,
        "example": "2026-04-30T12:00:00.000Z"
      }
    }
  },
  "views": {
    "overview": {
      "title": "Leads Overview",
      "description": "Scraped business leads from Google Maps — one row per business.",
      "transformation": {
        "fields": [
          "name", "category", "address", "phone", "website", "email",
          "rating", "reviewsCount", "priceRange", "placeId",
          "latitude", "longitude", "searchQuery", "scrapedAt"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "name": { "label": "Business Name", "format": "text", "sortable": true },
          "category": { "label": "Category", "format": "text", "sortable": true },
          "address": { "label": "Address", "format": "text", "sortable": true },
          "phone": { "label": "Phone", "format": "tel", "sortable": true },
          "website": { "label": "Website", "format": "uri" },
          "email": { "label": "Email", "format": "email", "sortable": true },
          "rating": { "label": "Rating", "format": "number", "sortable": true },
          "reviewsCount": { "label": "Reviews", "format": "number", "sortable": true },
          "priceRange": { "label": "Price", "format": "text" },
          "imageUrl": { "label": "Photo", "format": "image" },
          "latitude": { "label": "Latitude", "format": "number" },
          "longitude": { "label": "Longitude", "format": "number" },
          "searchQuery": { "label": "Search", "format": "text" },
          "scrapedAt": { "label": "Scraped At", "format": "date-time", "sortable": true }
        }
      }
    }
  }
}
